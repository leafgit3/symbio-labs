# Copy this file to .env.local and fill in real values.
# Runtime will fall back to in-memory mode if Supabase vars are missing.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (required for cloud persistence)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# CLI convenience (optional, used when linking/pushing manually)
SUPABASE_PROJECT_REF=your-project-ref

# Optional LLM (OpenAI-compatible endpoint)
# If omitted, agent turns use deterministic fallback logic.
LLM_BASE_URL=https://your-agent-endpoint.agents.do-ai.run
LLM_API_KEY=your-agent-key
